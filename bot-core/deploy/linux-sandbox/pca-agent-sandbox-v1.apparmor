abi <abi/4.0>,
include <tunables/global>

# PCA's confined outer Docker profile for a direct Claude agent that has
# workspace-scoped Bash enabled. Bubblewrap needs user-namespace and mount
# setup rights, but the command it launches is stacked into the final profile
# below, which denies every Linux capability. This works with
# no-new-privileges; never replace it with an unconfined or privileged profile.
profile pca-agent-sandbox-v1 flags=(attach_disconnected,mediate_deleted) {
  network,
  deny network alg,
  capability,
  file,
  umount,
  userns,
  mount,
  pivot_root,
  unix,
  signal,
  ptrace,
  mqueue,
  io_uring,
  dbus,

  /usr/bin/bwrap pix -> &pca-agent-bwrap-v1,

  signal (receive) peer=unconfined,
  signal (receive) peer=runc,
  signal (receive) peer=crun,
  signal (receive) peer=docker-default,
  signal (send,receive) peer=pca-agent-sandbox-v1,

  # Keep the kernel and procfs protections from Docker's default profile.
  deny @{PROC}/* w,
  deny @{PROC}/{[^1-9/],[^1-9/][^0-9/],[^1-9s/][^0-9y/][^1-9s/],[^1-9/][^0-9/][^1-9/][^0-9/][^1-9/]*}/** w,
  deny @{PROC}/sys/[^k]** w,
  deny @{PROC}/sys/kernel/{?,??,[^s][^h][^m]**} w,
  deny @{PROC}/sysrq-trigger rwklx,
  deny @{PROC}/kcore rwklx,
  deny /sys/[^f]*/** wklx,
  deny /sys/f[^s]*/** wklx,
  deny /sys/fs/[^c]*/** wklx,
  deny /sys/fs/c[^g]*/** wklx,
  deny /sys/fs/cg[^r]*/** wklx,
  deny /sys/firmware/** rwklx,
  deny /sys/devices/virtual/powercap/** rwklx,
  deny /sys/kernel/security/** rwklx,
}

# Setup rights apply only to Bubblewrap while it constructs its inner namespace.
profile pca-agent-bwrap-v1 /usr/bin/bwrap flags=(attach_disconnected,mediate_deleted) {
  capability,
  /{,**} rwlkm,
  network,
  unix,
  ptrace,
  signal,
  mqueue,
  io_uring,
  userns,
  mount,
  umount,
  pivot_root,
  dbus,

  /{,**} pix -> &pca-agent-bwrap-v1//&pca-agent-unpriv-bwrap-v1,
}

# A model-controlled command is always additionally stacked with this profile.
# It may use ordinary files and IPC, but has no Linux capabilities (including
# CAP_SYS_ADMIN) after the namespace setup is complete.
profile pca-agent-unpriv-bwrap-v1 flags=(attach_disconnected,mediate_deleted) {
  /{,**} rwlkm,
  network,
  unix,
  ptrace,
  signal,
  mqueue,
  io_uring,
  userns,
  mount,
  umount,
  pivot_root,
  dbus,

  /{,**} pix -> &pca-agent-unpriv-bwrap-v1,
  audit deny capability,
}
